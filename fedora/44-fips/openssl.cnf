# OpenSSL Configuration for Fedora 44 with wolfProvider
# FIPS 140-3 Configuration using wolfSSL v5.8.2 (Certificate #4718)
#
# This configuration file forces all OpenSSL operations to use wolfProvider,
# which provides FIPS-approved cryptographic operations via wolfSSL.
#
# Architecture: OpenSSL 3.x → wolfProvider → wolfSSL FIPS v5.8.2

openssl_conf = openssl_init

[openssl_init]
providers = provider_sect
alg_section = algorithm_sect

[provider_sect]
# wolfProvider - Primary FIPS provider using wolfSSL FIPS v5.8.2
libwolfprov = libwolfprov_sect

[libwolfprov_sect]
activate = 1
# Module path: System-wide OpenSSL modules directory
module = /usr/lib64/ossl-modules/libwolfprov.so

[algorithm_sect]
# Enforce FIPS-approved algorithms only
# This property ensures only FIPS-compliant algorithms are used
default_properties = fips=yes
