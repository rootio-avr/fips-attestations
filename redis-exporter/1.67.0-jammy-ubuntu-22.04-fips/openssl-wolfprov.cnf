# OpenSSL Configuration with wolfProvider (FIPS Mode)
# This configuration routes all cryptographic operations through wolfSSL FIPS v5.8.2

openssl_conf = openssl_init

[openssl_init]
providers = provider_sect

[provider_sect]
fips = fips_sect
base = base_sect

[base_sect]
activate = 1

[fips_sect]
activate = 1
module = /usr/lib/x86_64-linux-gnu/ossl-modules/libwolfprov.so
